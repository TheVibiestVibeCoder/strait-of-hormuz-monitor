# Copy this file to .env and fill in real values.

AISSTREAM_API_KEY=CHANGE_ME

ALERT_EMAIL=alerts@example.com
FROM_EMAIL=hormuz-monitor@example.com

# Optional overrides.
DB_PATH=hormuz.db
COLLECTOR_STATE_PATH=collector_state.json

BBOX_SW_LAT=25.5
BBOX_SW_LON=55.0
BBOX_NE_LAT=27.0
BBOX_NE_LON=58.0

COLLECTOR_RUNTIME=50
COLLECTOR_TIMEOUT_SECONDS=25
MIN_SECONDS_BETWEEN_SIGHTINGS=120
ACTIVE_VESSEL_WINDOW_MINUTES=90
DATA_RETENTION_DAYS=14

# 900 seconds = 15 minutes
DASHBOARD_REFRESH_SECONDS=900

BASELINE_TANKERS_PER_DAY=16
ALERT_L1_MULTIPLIER=1.4
ALERT_L2_MULTIPLIER=0.8
